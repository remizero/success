# Nombre del módulo WSGI
FLASK_APP=wsgi.py

# Modo producción (debe estar en minúscula)
FLASK_ENV=production

# Desactiva el debugger de Flask
FLASK_DEBUG=0

# Base de datos (ya lo tienes, perfecto)
DATABASE_URL=sqlite:///app.sqlite3

# Clave secreta para sesiones y CSRF (¡bien ahí!)
SECRET_KEY=your-secret-key-change-me

# Ruta al archivo de autorización
AUTHZ_FILE=authorization.yaml

# Registro opcional (si implementas logging por archivo o consola)
LOG_LEVEL=INFO

# Opcional para trazas más detalladas (solo si usas Sentry u otro sistema)
APP_VERSION=1.0.0
