# ---------------------------------------------------------
# Cors Opcional Configuration / Configuración Opcional Cors
# Estas macros son especiales y personalizadas para el correcto manejo de las políticas de Cors en flask para diferentes dominios de manera personalizada.
# ---------------------------------------------------------
# CORS_RESOURCES_APP_RESOURCES = [ r'/admin/*', r'/core/*' ]
# CORS_RESOURCES_APP_ORIGINS = [ [ 'http://example.com:5000' ] ]
# CORS_RESOURCES_APP_METHODS = [ [ 'GET', 'POST', 'PUT', 'DELETE' ] ]
# CORS_RESOURCES_APP_ALLOW_HEADERS = [ [ 'Authorization', 'Content-Type', 'X-Requested-With', 'Accept', 'Set-Cookie' ] ]
# CORS_RESOURCES_APP_EXPOSE_HEADERS = [ [ 'Content-Type', 'X-CSRFToken' ] ]


# -----------------------------------------
# Flask Configuration / Configuración Flask
# -----------------------------------------
# - Project name.
# FLASK_APP = 'wsgi:successApp'
# - Controls the environment.
# FLASK_ENV = 'development'
#  - Enables debug mode.
# FLASK_DEBUG = True
# - A list of files that will be watched by the reloader in addition to the Python modules.
# FLASK_RUN_EXTRA_FILES =
# - The host you want to bind your apps to.
# FLASK_RUN_HOST = 0.0.0.0
# - The port you want to use.
# FLASK_RUN_PORT = 5000
# - A certificate file for so your apps can be run with HTTPS.
# FLASK_RUN_CERT =
# - The key file for your cert.
# FLASK_RUN_KEY = 'laclavemassecretaquepuedeexistir'


# ---------------------------------------
# JWT Configuration / Configuración JWT
# ---------------------------------------
# Set a new name to token cookies
# JWT_ACCESS_COOKIE_NAME = 'access_token_cookie'
# Set the cookie paths
# JWT_ACCESS_COOKIE_PATH = /
# JWT_ACCESS_CSRF_COOKIE_NAME = csrf_access_token
# JWT_ACCESS_CSRF_COOKIE_PATH = /
# JWT_ACCESS_CSRF_FIELD_NAME = csrf_token
# Set header access name for csrf
# JWT_ACCESS_CSRF_HEADER_NAME = 'X-CSRF-TOKEN-ACCESS'
# Se define el tiempo de duración del token de acceso
# JWT_ACCESS_TOKEN_EXPIRES = 86400
# JWT_ALGORITHM = HS256
# JWT_BLOCKLIST_ENABLED = True
# JWT_BLOCKLIST_TOKEN_CHECKS = [ 'access', 'refresh' ]
# Enable csrf double submit protection.
# JWT_COOKIE_CSRF_PROTECT = True
# Se define el dominio sobre el cual se crearan las cookies
# HABILITAR SOLO PARA MODO DE DESARROLLO EN LOCAL
# HABILITAR PARA MODO SUCCESS_STAGING Y/O PRODUCCION
#JWT_COOKIE_DOMAIN = 'http://example.com:5000'
# JWT_COOKIE_SAMESITE = None
# Only allow JWT cookies to be sent over https. In production, this should likely be True
# JWT_COOKIE_SECURE = False
# Set csrf check form
# JWT_CSRF_CHECK_FORM = True
# JWT_CSRF_IN_COOKIES = True
# Set allowed methods for csrf
# JWT_CSRF_METHODS = [ 'DELETE', 'GET', 'POST', 'PUT' ]
# JWT_DECODE_ALGORITHMS = None
# JWT_DECODE_AUDIENCE = None
# JWT_DECODE_ISSUER = None
# JWT_DECODE_LEEWAY = 0
# JWT_ENCODE_AUDIENCE = None
# JWT_ENCODE_ISSUER = None
# Se define el índice que devolverá los errores generados para la sesión
# JWT_ERROR_MESSAGE_KEY = 'message'
# JWT_HEADER_NAME = Authorization
# JWT_HEADER_TYPE = Bearer
# JWT_IDENTITY_CLAIM = sub
# JWT_JSON_KEY = access_token
# JWT_PRIVATE_KEY = None
# JWT_PUBLIC_KEY = None
# JWT_QUERY_STRING_NAME = jwt
# JWT_QUERY_STRING_VALUE_PREFIX = 
# Set a new name to token cookies
# JWT_REFRESH_COOKIE_NAME = 'refresh_token_cookie'
# Set the cookie paths
# JWT_REFRESH_COOKIE_PATH = /
# JWT_REFRESH_CSRF_COOKIE_NAME = csrf_refresh_token
# JWT_REFRESH_CSRF_COOKIE_PATH = /
# JWT_REFRESH_CSRF_FIELD_NAME = csrf_token
# Set header refresh name for csrf
# JWT_REFRESH_CSRF_HEADER_NAME = 'X-CSRF-TOKEN-REFRESH'
# JWT_REFRESH_JSON_KEY = refresh_token
# Se define el tiempo de duración del token de reingreso o relogin
# JWT_REFRESH_TOKEN_EXPIRES = 86400
# Set the secret key to sign the JWTs with
# JWT_SECRET_KEY = 'your-secret-key-change-me'  # Change this!
# JWT_SESSION_COOKIE = True
# Configure application to store JWTs in cookies
# JWT_TOKEN_LOCATION = ['cookies']
# JWT_ENCODE_NBF = True


# ---------------------------------------
# Logger Configuration / Configuración Logger
# ---------------------------------------
LOGGER_ADMIN = 'admin@example.com'
LOGGER_BACKUP_COUNT = 30
LOGGER_CONSOLE = True
LOGGER_DIR = './log/error_success.log'
LOGGER_ENCODING = 'utf-8'
LOGGER_FILE = True
LOGGER_FORMAT = f"%(asctime)s - [%(levelname)s] - %(name)s - (%(filename)s).%(funcName)s(%(lineno)d) - %(message)s - %(threadName)s"
LOGGER_FORMATER = 'json'
LOGGER_LEVEL = 'ERROR'
LOGGER_MAIL_ENABLED = False
LOGGER_MAIL_PASSWORD = 'your-mail-password'
LOGGER_MAIL_PORT = 587
LOGGER_MAIL_SERVER = 'smtp.example.com'
LOGGER_MAIL_SSL = False
LOGGER_MAIL_TLS = True
LOGGER_MAIL_USERNAME = 'admin@example.com'
LOGGER_MAX_BYTES = 1000000
LOGGER_MAX_RETRIES = 3
LOGGER_MESSAGE_SUBJECT = 'Alerta critica en el sistema'
LOGGER_ROTATE_INTERVAL = 1
LOGGER_TEMPLATE_FORMAT_MESSAGE = 
LOGGER_TEMPLATE_HTML_ERROR = 'SuccessErrorAlert.html'
LOGGER_TEMPLATE_HTML_EXCEPTION = 'SuccessExceptionAlert.html'
LOGGER_ROTATE_WHEN = 'midnight'


